// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id        String     @id @default(cuid())
  email     String     @unique
  name      String?
  auth0Id   String     @unique
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  debts                   Debt[]
  income                  Income?
  expenses                Expense[]
  bonusIncomes            BonusIncome[]
  payoffPlan              PayoffPlan?
  aiRecommendationCache   AiRecommendationCache?

  @@map("users")
}

model Debt {
  id                String   @id @default(cuid())
  userId            String
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  name              String
  category          String   // Credit Card, Student Loan, Auto Loan, Mortgage, Personal Loan, Medical Debt, Other
  balance           Float    @default(0)
  originalBalance   Float    @default(0)
  interestRate      Float    @default(0) // APR in percentage
  minimumPayment    Float    @default(0)
  creditLimit       Float    @default(0) // for credit cards
  priorityOrder     Int?
  dueDate           Int?     // day of month (1-31)

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  payoffSchedule    PayoffStep[]
  snapshots         BalanceSnapshot[]

  @@index([userId])
  @@map("debts")
}

model Income {
  id                String   @id @default(cuid())
  userId            String   @unique
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  monthlyTakeHome    Float    @default(0)
  essentialExpenses  Float    @default(0) // rent, utilities, groceries, insurance (excluding debt)
  extraPayment       Float    @default(0) // extra amount available for debt payoff

  payoffMethod       String   @default("snowball") // snowball, avalanche, custom
  accelerationAmount Float?   // null = use full available cash flow

  source            String?  // W2, 1099, etc.
  frequency         String   @default("monthly") // monthly, bi-weekly, etc.

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@map("income")
}

model Expense {
  id                String   @id @default(cuid())
  userId            String
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  name              String
  amount            Float
  frequency         String   @default("monthly") // monthly, bi-weekly, one-time
  category          String   // utilities, subscriptions, food, etc.

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([userId])
  @@map("expenses")
}

// ---------------------------------------------------------------------------
// Bonus Income — itemized irregular/variable income sources (commissions,
// bonuses, freelance, side income, etc.) that supplement the regular
// monthly take-home. Each entry is normalised to a monthly equivalent
// for payoff calculations.
// ---------------------------------------------------------------------------
model BonusIncome {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  name      String            // e.g. "Sales Commission", "Annual Bonus"
  amount    Float             // per-occurrence amount
  frequency String            // monthly | annual

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@map("bonus_income")
}

// ---------------------------------------------------------------------------
// Balance Snapshot — one entry per debt per month recording the statement
// balance. Plotting these against the projected line shows actual vs plan.
//
// TODO: If per-payment granularity is needed in the future (e.g. "I paid $X
//       extra this month"), replace or extend this with a DebtPayment model
//       that logs (amount, paidAt, note) per transaction instead of a monthly
//       balance summary.
// ---------------------------------------------------------------------------
model BalanceSnapshot {
  id         String   @id @default(cuid())
  debtId     String
  debt       Debt     @relation(fields: [debtId], references: [id], onDelete: Cascade)
  userId     String

  balance    Float    // statement balance for this month
  recordedAt DateTime // normalized to the 1st of the month

  createdAt  DateTime @default(now())

  @@unique([debtId, recordedAt])
  @@index([userId])
  @@map("balance_snapshots")
}

model PayoffPlan {
  id                String   @id @default(cuid())
  userId            String   @unique
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  debtFreeDate      DateTime
  totalInterestPaid Float    @default(0)
  totalAmountPaid   Float    @default(0)
  monthlyPayment    Float    @default(0)

  payoffSteps       PayoffStep[]

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@map("payoff_plans")
}

model PayoffStep {
  id                String   @id @default(cuid())
  debtId            String
  debt              Debt     @relation(fields: [debtId], references: [id], onDelete: Cascade)

  payoffPlanId      String
  payoffPlan        PayoffPlan @relation(fields: [payoffPlanId], references: [id], onDelete: Cascade)

  stepNumber        Int      // order in payoff sequence
  startBalance      Float
  payoffMonth       Int      // month when this debt is paid off
  interestPaid      Float    @default(0)

  @@index([debtId])
  @@index([payoffPlanId])
  @@map("payoff_steps")
}

// ---------------------------------------------------------------------------
// AI Recommendation Cache — one row per user, upserted each time new
// recommendations are generated. dataHash is a fingerprint of the financial
// data used so the UI can detect when advice is stale.
// ---------------------------------------------------------------------------
model AiRecommendationCache {
  id              String   @id @default(cuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  recommendations Json     // AiRecommendation[]
  dataHash        String   // fingerprint — changes when debts/income change

  generatedAt     DateTime @default(now())

  @@map("ai_recommendation_cache")
}

model UploadedDocument {
  id                String   @id @default(cuid())
  userId            String
  fileName          String
  fileType          String   // "income_statement", "debt_list", etc.
  fileUrl           String
  extractedData     Json?    // store extracted data as JSON
  status            String   @default("uploaded") // uploaded, processing, completed

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([userId])
  @@map("uploaded_documents")
}
